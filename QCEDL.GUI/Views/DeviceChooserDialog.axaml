<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:QCEDL.GUI.ViewModels"
        xmlns:core="clr-namespace:Qualcomm.EmergencyDownload.Core;assembly=QCEDL.NET"
        x:Class="QCEDL.GUI.Views.DeviceChooserDialog"
        x:DataType="vm:DeviceChooserDialogViewModel"
        Title="{Binding Title}"
        Width="560"
        Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Background="{DynamicResource BrushParchment}" Padding="28">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Spacing="10">
                <TextBlock Classes="h2" Text="{Binding Title}" />
                <TextBlock Classes="body" Text="{Binding Prompt}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
                <Button Classes="ghost"
                        Content="{Binding CancelLabel}"
                        Click="OnCancel" />
                <Button Classes="primary"
                        Content="{Binding ConfirmLabel}"
                        IsEnabled="{Binding CanConfirm}"
                        Click="OnConfirm" />
            </StackPanel>
            <ListBox Margin="0,16,0,0"
                     ItemsSource="{Binding Candidates}"
                     SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                     MaxHeight="260">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="core:DeviceCandidate">
                        <StackPanel Spacing="2" Margin="4,6">
                            <TextBlock Classes="body" Text="{Binding DisplayName}" />
                            <TextBlock Classes="caption" Text="{Binding Details}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</Window>
