<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QCEDL.GUI.ViewModels"
             x:Class="QCEDL.GUI.Views.ConnectionView"
             x:DataType="vm:ConnectionViewModel">
    <StackPanel Spacing="20" MaxWidth="780">
        <StackPanel Spacing="6">
            <TextBlock Classes="label" Text="CONNECTION" />
            <TextBlock Classes="h1" Text="Target &amp; Session" />
            <TextBlock Classes="body" Text="Choose how to reach the device: USB via Sahara/Firehose, or a direct host-device backend. The GUI mirrors the CLI global options." />
        </StackPanel>

        <!-- Programmer, USB & transport backend -->
        <Border Classes="card">
            <StackPanel Spacing="14">
                <TextBlock Classes="h3" Text="Programmer &amp; Transport" />
                <TextBlock Classes="caption" Text="Choose libusb (WinUSB / LibUsbDotNet) or the serial driver. Auto picks libusb on Windows and serial on Linux/macOS." />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="body" Text="Loader (.elf / .xml)" VerticalAlignment="Center" />
                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" Text="{Binding LoaderPath}" PlaceholderText="Path to Firehose programmer or qsahara_device_programmer.xml" />
                        <Button Grid.Column="1" Content="Browse…" Click="OnBrowseLoader" />
                    </Grid>

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="body" Text="Backend" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Backends}" SelectedItem="{Binding Backend}" MinWidth="200" HorizontalAlignment="Left" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="body" Text="USB VID (hex)" VerticalAlignment="Center" IsVisible="{Binding IsUsbBackend}" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding VidHex}" PlaceholderText="05C6" IsVisible="{Binding IsUsbBackend}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="body" Text="USB PID (hex)" VerticalAlignment="Center" IsVisible="{Binding IsUsbBackend}" />
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PidHex}" PlaceholderText="9008" IsVisible="{Binding IsUsbBackend}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="body" Text="Serial device" VerticalAlignment="Center" IsVisible="{Binding IsSerialBackend}" />
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SerialDevicePath}" PlaceholderText="/dev/ttyUSB0, /dev/tty.usbserial-…, or auto-detect on Windows/Linux" IsVisible="{Binding IsSerialBackend}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="body" Text="Memory" VerticalAlignment="Center" />
                    <ComboBox Grid.Row="5" Grid.Column="1" ItemsSource="{Binding MemoryTypes}" SelectedItem="{Binding MemoryType}" MinWidth="200" HorizontalAlignment="Left" />

                    <TextBlock Grid.Row="6" Grid.Column="0" Classes="body" Text="Slot" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Row="6" Grid.Column="1" Value="{Binding Slot}" Minimum="0" Maximum="7" Increment="1" FormatString="0" MaxWidth="140" HorizontalAlignment="Left" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Classes="card">
            <StackPanel Spacing="14">
                <TextBlock Classes="h3" Text="Direct modes" />
                <TextBlock Classes="caption" Text="Bypass USB/Firehose entirely when flashing a host block device or file-backed image." />
                <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="14">
                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="body" Text="Host device" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HostDevTarget}" PlaceholderText="/dev/mtd0 or /path/to/file.img" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="body" Text="Image size" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ImgSize}" PlaceholderText="32M / 1G / 512K (only when creating a file)" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="body" Text="Radxa WoS" VerticalAlignment="Center" IsVisible="{Binding IsWindows}" />
                    <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding RadxaWos}" Content="Use Radxa Windows-on-Snapdragon SPI NOR backend (Windows only)" IsVisible="{Binding IsWindows}" />
                </Grid>
            </StackPanel>
        </Border>

        <Border Classes="card">
            <StackPanel Spacing="12">
                <TextBlock Classes="h3" Text="Status" />
                <TextBlock Classes="body" Text="{Binding StatusText}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Classes="caption" Text="Mode:" />
                    <TextBlock Classes="mono" Text="{Binding ModeText}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Classes="primary" Content="Connect" Command="{Binding ConnectCommand}" />
                    <Button Content="Probe mode" Command="{Binding ProbeCommand}" />
                    <Button Classes="ghost" Content="Disconnect" Command="{Binding DisconnectCommand}" />
                    <ProgressBar IsVisible="{Binding IsBusy}" IsIndeterminate="True" Width="140" VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
