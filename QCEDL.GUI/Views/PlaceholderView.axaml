<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:QCEDL.GUI.ViewModels"
             x:Class="QCEDL.GUI.Views.PlaceholderView"
             x:DataType="vm:PlaceholderViewModel">
    <StackPanel Spacing="16" MaxWidth="640">
        <TextBlock Classes="label" Text="COMING SOON" />
        <TextBlock Classes="h1" Text="{Binding Title}" />
        <Border Classes="card">
            <TextBlock Classes="body" TextWrapping="Wrap" Text="{Binding Description}" />
        </Border>
    </StackPanel>
</UserControl>
